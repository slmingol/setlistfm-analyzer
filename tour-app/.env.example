SETLISTFM_API_KEY=your_setlistfm_api_key
SETLISTFM_USERNAME=your_setlistfm_username

# Ticketmaster Developer Portal → your app → "Consumer Key"
# (Consumer Secret is NOT needed — that's for OAuth/Live Connect only)
TICKETMASTER_API_KEY=your_ticketmaster_consumer_key

# Optional
PORT=3234
SYNC_ON_START=true
CRON_SCHEDULE=0 12 * * 1

# Optional
STATUS_SYNC_SCHEDULE=0 14 * * 1
